# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/inmodata_ia"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-in-production-use-32-plus-chars"
JWT_EXPIRES_IN="7d"

# ── Google Gemini (LLM) ───────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key-here"
GEMINI_MODEL="gemini-1.5-pro"

# ── Vector DB (pgvector — usa la misma DATABASE_URL, no se necesita proveedor adicional) ──
# Si en el futuro migras a Pinecone o Qdrant, agrega aquí:
# PINECONE_API_KEY=""
# PINECONE_INDEX=""

# ── Scraping ──────────────────────────────────────────────────────────────────
# NOTA: Revisar robots.txt y TdS de Urbania/Adondevivir antes de producción.
SCRAPING_ENABLED="false"
SCRAPING_INTERVAL_MINUTES="60"
# IMPORTANTE: NO usar nombres bloqueados por robots.txt (Scrapy, wget, HTTrack, etc.)
SCRAPING_USER_AGENT="InmoDataIA-Bot/1.0 (contact@inmodata.ia)"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"
CORS_ORIGIN="http://localhost:5173"
